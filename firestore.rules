rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Funciones de ayuda globales
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Usuarios: Lectura pública, escritura solo el dueño
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
    
    // Publicaciones: Lectura pública, creación para autenticados
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      // Permitir actualización si estás logueado (para likes/comentarios) 
      // o si eres el dueño para editar el contenido
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }
    
    // Comentarios: Lectura pública, creación para autenticados
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.authorId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // Reels: Lectura pública
    match /reels/{reelId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // Chats: Solo participantes pueden leer y actualizar
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow delete: if false; // Por ahora no permitimos borrar chats completos
    }

    // Mensajes: Lectura permitida si el usuario está autenticado 
    // (el filtro por chatId en el cliente asegura la privacidad)
    match /messages/{messageId} {
      allow read: if isSignedIn(); 
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }

    // Historias: Lectura pública
    match /stories/{storyId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // Marketplace: Venta P2P
    match /marketplace/{itemId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.sellerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.sellerId == request.auth.uid;
    }

    // Seguidores y Amigos
    match /followers/{followId} {
      allow read: if true;
      allow create, delete: if isSignedIn();
    }
    
    match /following/{followId} {
      allow read: if true;
      allow create, delete: if isSignedIn();
    }
  }
}