rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Funciones de ayuda globales
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Usuarios: Lectura pública, creación para autenticados, actualización solo dueño
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
    
    // Publicaciones: Lectura pública, creación/likes/comentarios para autenticados
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // Permitir likes y contadores
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }
    
    // Comentarios: Lectura pública, creación/edición para autenticados
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.authorId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // Reels: Lectura pública
    match /reels/{reelId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // Chats: Participantes pueden leer y actualizar
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow delete: if false;
    }

    // Mensajes: Lectura permitida si el usuario está autenticado 
    match /messages/{messageId} {
      allow read: if isSignedIn(); 
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }

    // Historias: Lectura pública
    match /stories/{storyId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // Marketplace: Lectura pública, gestión para dueños
    match /marketplace/{itemId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.sellerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.sellerId == request.auth.uid;
    }

    // Seguidores, Amigos, Bloqueos, Reportes
    match /followers/{id} { allow read, write: if isSignedIn(); }
    match /following/{id} { allow read, write: if isSignedIn(); }
    match /friends/{id} { allow read, write: if isSignedIn(); }
    match /blockedUsers/{id} { allow read, write: if isSignedIn(); }
    match /reports/{id} { allow read: if isSignedIn(); allow create: if isSignedIn(); }
    match /notifications/{id} { allow read, write: if isSignedIn(); }
  }
}